generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  EMPLOYEE
}

enum PlanTier {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum EntryStatus {
  CLOCKED_IN
  CLOCKED_OUT
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  timezone  String   @default("UTC")
  locale    String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  timeEntries   TimeEntry[]
  subscription  Subscription?
  kioskSessions KioskSession[]
  invites       Invite[]
  activityLogs  ActivityLog[]
  schedules     Schedule[]
  isPro         Boolean  @default(false)
  licenseKey    String?
  alertEmail    String?
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  name           String
  role           UserRole @default(EMPLOYEE)
  isActive       Boolean  @default(true)
  pin            String?
  avatarUrl      String?
  locale         String?
   hourlyRate     Float?   // salario por hora normal
  overtimeRate   Float?   // salario por hora extra
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timeEntries  TimeEntry[]
  accounts     Account[]
  sessions     Session[]
  schedule          Schedule?
  pushSubscription  PushSubscription?

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TimeEntry {
  id             String      @id @default(cuid())
  organizationId String
  userId         String
  clockIn        DateTime
  clockOut       DateTime?
  status         EntryStatus @default(CLOCKED_IN)
  source         String      @default("web")
  note           String?
  durationMin    Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([organizationId, clockIn])
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  tier                 PlanTier           @default(BASIC)
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  employeeLimit        Int                @default(5)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model KioskSession {
  id             String   @id @default(cuid())
  organizationId String
  token          String   @unique @default(cuid())
  name           String   @default("Main Kiosk")
  isActive       Boolean  @default(true)
  exitPin        String
  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Invite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           UserRole  @default(EMPLOYEE)
  token          String    @unique @default(cuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
}
model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  userName       String
  action         String
  details        String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model Schedule {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @unique
  monday         Boolean  @default(true)
  tuesday        Boolean  @default(true)
  wednesday      Boolean  @default(true)
  thursday       Boolean  @default(true)
  friday         Boolean  @default(true)
  saturday       Boolean  @default(false)
  sunday         Boolean  @default(false)
  startTime      String   @default("08:00")
  endTime        String   @default("17:00")
  toleranceMin   Int      @default(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
model PushSubscription {
  id           String   @id @default(cuid())
  userId       String   @unique
  subscription String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}